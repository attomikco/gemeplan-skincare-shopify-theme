<script>
(function(){
  var ss = '<svg width="WW" height="WW" viewBox="0 0 24 24"><use href="#gp-star"/></svg>';
  function stars(n, w) {
    var o = '';
    for (var i = 0; i < n; i++) o += ss.replace(/WW/g, w);
    return o;
  }

  /* Marquee */
  var items = [
    ['M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z', 'Engineered for Athletes'],
    ['M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z', 'Alcohol-Free Formula'],
    ['M22 11.08V12a10 10 0 1 1-5.93-9.14M22 4l-10 10.01-3-3', 'Removes Eyeblack'],
    ['M9 12l2 2 4-4m6 2a9 9 0 1 1-18 0 9 9 0 0 1 18 0z', 'Paraben &amp; Dye Free'],
    ['M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z', '100% Biodegradable'],
    ['M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z', 'Cruelty-Free'],
    ['M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z', 'Eucalyptus Scent'],
    ['M5 12h14M12 5l7 7-7 7', 'Instant Refresh']
  ];
  var mh = '';
  for (var r = 0; r < 2; r++) {
    for (var i = 0; i < items.length; i++) {
      mh += '<span class="gp-mq-i"><span class="gp-mq-ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#EF3340" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="' + items[i][0] + '"/></svg></span>' + items[i][1] + '</span><span class="gp-mq-sp">&bull;</span>';
    }
  }
  document.getElementById('gp-mq-track').innerHTML = mh;

  /* Stars hero */
  document.getElementById('gp-stars-big').innerHTML = stars(5, 20);

  /* Reviews */
  var revs = [
    ['I use these after every workout, my skin stays calm. Nothing else I have tried actually works post-sweat without leaving my face feeling tight or greasy.', 'Maya R.', 'M'],
    ['Best quick wipe for eyeblack removal and locker room clean up. Using them now for baseball and they were great this fall for football.', 'Levi A.', 'L'],
    ['Bought for my kids to use on bus after practices and games. No longer sitting in their sweat on way home. Great product and smells nice.', 'Adrian M.', 'A'],
    ['Our son is a soccer goalie and daughter does XC. They each keep a pack in their PE bags and I keep them in my car. We don\'t leave practice until they use one.', 'Ashley G.', 'AG'],
    ['I\'ll never use paper towels again to take off my eyeblack. These get everything off fast and my skin feels way better after a long game day.', 'Jordan W.', 'J'],
    ['Finally something that doesn\'t burn when I\'m sweaty. Clean, hydrated, not greasy at all — exactly what I needed for after practice.', 'Emily S.', 'E']
  ];
  var rh = '';
  for (var i = 0; i < revs.length; i++) {
    rh += '<div class="gp-rv-c"><div class="gp-rv-stars">' + stars(5, 14) + '</div><p class="gp-rv-txt">&ldquo;' + revs[i][0] + '&rdquo;</p><div class="gp-rv-auth"><div class="gp-rv-av">' + revs[i][2] + '</div><div><div class="gp-rv-nm">' + revs[i][1] + '</div><div class="gp-rv-badge">Verified Buyer</div></div></div></div>';
  }
  document.getElementById('gp-reviews-grid').innerHTML = rh;

  /* FAQ */
  var faqs = [
    ['What makes these different from regular wipes?', 'Most wipes strip or mask. GamePlan wipes cleanse sweat, salt, and oil while reinforcing your skin barrier — so irritation and breakouts don\'t build momentum. This is performance hygiene, not a baby wipe.'],
    ['Will this dry my skin out?', 'No. The formula is alcohol-free and contains humectants that restore hydration. You\'ll feel clean and refreshed — not tight or dry.'],
    ['Can I use it to remove eyeblack?', 'Yes — this is one of the most popular use cases. The wipes are large enough and strong enough to remove eyeblack fast without micro-abrasions or irritation.'],
    ['Is this just for teens or high school athletes?', 'Not at all. It\'s formulated for anyone with an active lifestyle — from high school athletes to NFL players to weekend warriors and fitness enthusiasts. If you sweat, it works for you.'],
    ['Can I use this on my body too?', 'Yes. The formula is safe for face, neck, head, and body. Many athletes use it for a full wipe-down between practices or on travel days.'],
    ['Does it contain alcohol?', 'No. We deliberately left alcohol out. It\'s a common ingredient in wipes but it strips your skin barrier — the opposite of what you want post-workout.'],
    ['How often can I use it?', 'Daily. The formula is gentle enough for everyday use. Most athletes use one wipe per session, keeping a pack in their bag and one in the car.'],
    ['Is it biodegradable?', 'Yes. The wipe material is 100% Rayon — fully biodegradable. No plastic fibers, no microplastics.']
  ];
  var chv = '<svg class="gp-fq-chv" viewBox="0 0 24 24"><use href="#gp-chv"/></svg>';
  var fh = '';
  for (var i = 0; i < faqs.length; i++) {
    var id = 'gp-fq-' + (i + 1);
    fh += '<div class="gp-fq-i"><input type="checkbox" class="gp-fq-tog" id="' + id + '"><label class="gp-fq-q" for="' + id + '">' + faqs[i][0] + chv + '</label><div class="gp-fq-a"><div class="gp-fq-a-in">' + faqs[i][1] + '</div></div></div>';
  }
  document.getElementById('gp-faq-list').innerHTML = fh;

  /* Final CTA — Add to Cart */
  function gpAddToCart(vid, btn) {
    var orig = btn.innerHTML;
    btn.innerHTML = 'Adding...';
    btn.style.pointerEvents = 'none';
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: [{ id: parseInt(vid), quantity: 1 }] })
    })
    .then(function(r) { return r.json(); })
    .then(function() {
      btn.innerHTML = '&#10003; Added!';
      setTimeout(function() { btn.innerHTML = orig; btn.style.pointerEvents = ''; }, 1800);
      var cd = document.querySelector('cart-drawer');
      if (cd && typeof cd.open === 'function') cd.open();
      document.dispatchEvent(new CustomEvent('cart:refresh'));
      document.dispatchEvent(new CustomEvent('cart:updated'));
    })
    .catch(function() { btn.innerHTML = orig; btn.style.pointerEvents = ''; });
  }

  var fcBtn = document.getElementById('gp-fc-atc-btn');
  if (fcBtn) {
    fcBtn.addEventListener('click', function(e) {
      e.preventDefault();
      var sel = document.querySelector('form[action="/cart/add"] [name="id"],form[action*="cart"] [name="id"]');
      if (sel) {
        gpAddToCart(sel.value, fcBtn);
      } else {
        var pdpBtn = document.querySelector('.product-form__submit,form[action="/cart/add"] button[type="submit"]');
        if (pdpBtn) pdpBtn.click();
        else window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    });
  }
})();
</script>

