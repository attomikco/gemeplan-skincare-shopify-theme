    "tabs_pPJfTK": {
      "type": "tabs",
      "blocks": {
        "content_KR9AFb": {
          "type": "content",
          "settings": {
            "tab": "For Athletes",
            "content": "<h6>REFRESH & RECOVER</h6><p>A facial cleansing solution for your on-the-go lifestyle. Our formula is engineered for sport, and formulated by Korean skincare experts. Our wipes avoid the micro-abrasions and chemical ingredients of our competitors and instead offer gentle, clean ingredients that will leave your skin fresh and replenished. We created a wipe that is non-stripping, non-irritating, and strong enough to tackle sweat and dirt no matter when or where.</p><p>Our wipes have plenty of real estate to swipe sweat, made of 100% Rayon biodegradable material.</p><p>Lightly scented with our signature eucalyptus scent to leave skin invigorated.</p>"
          }
        },
        "content_Lfk9RG": {
          "type": "content",
          "settings": {
            "tab": "Ingredients",
            "content": "<h6>Ingredients</h6><p>Water, Butylene Glycol, Glycerin, Sodium Hyaluronate, 1,2-Hexanediol, Glycereth-26, Polyglyceryl-10 Laurate, Sorbeth-30 Tetraoleate, Chamomilla Recutita Flower Extract, Eucalyptus Globulus Leaf Oil, Olea Europaea Fruit Oil, Camellia Sinensis Leaf Extract, Cucumis Sativus (Cucumber) Fruit Extract, Caprylic/Capric Triglyceride, Sodium benzoate, Disodium EDTA, Phenoxyethanol, Ethylhexylglycerin, Citric acid.</p>"
          }
        },
        "content_F7r9bE": {
          "type": "content",
          "settings": {
            "tab": "Usage & Details",
            "content": "<h6>Directions:</h6><p>Use in sweeping and circular motions all over face and neck. No need to rinse. Avoid direct contact in eyes.</p><h6>Details:</h6><p>Best used after workouts, activity, or any time you need a quick refresh throughout the day.</p>"
          }
        }
      },
