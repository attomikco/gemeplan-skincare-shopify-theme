          "type": "content",
          "settings": {
            "heading": "What makes these different from regular wipes?",
            "content": "<p>Most wipes strip or mask.<br/><br/>GamePlan wipes cleanse sweat, salt, and oil while reinforcing your skin barrier \u2014 so irritation and breakouts don\u2019t build momentum.</p><p>This is performance hygiene, not a baby wipe.</p>",
            "icon": "",
            "color_scheme": "btn",
            "enable_open": true
          }
        },
        "content_GrH4dd": {
          "type": "content",
          "settings": {
            "heading": "Will this dry my skin out?",
            "content": "<p>No. Our formula hydrates while it cleanses.</p><p>We remove excess oil and buildup without triggering rebound dryness.</p>",
            "icon": "",
            "color_scheme": "btn",
            "enable_open": false
          }
        },
        "content_xQRVyJ": {
          "type": "content",
          "disabled": true,
          "settings": {
            "heading": "Is it safe for acne-prone skin?",
            "content": "<p>Yes. It\u2019s non-comedogenic and designed to prevent sweat-driven breakouts by keeping pores clear after activity.</p>",
            "icon": "",
            "color_scheme": "btn",
            "enable_open": false
          }
        },
        "content_edHrmi": {
          "type": "content",
          "settings": {
            "heading": "Is this just for teens?",
            "content": "<p>No. It\u2019s built for anyone who trains hard and sweats \u2014 youth athletes, college, pros, weekend warriors.</p><p>If you sweat, it\u2019s for you.</p>",
            "icon": "",
            "color_scheme": "btn",
            "enable_open": false
          }
        },
        "content_MMdqcQ": {
          "type": "content",
          "settings": {
            "heading": "Can I use this on my body too?",
            "content": "<p>Yes. Safe for face, neck, chest, and back \u2014 anywhere sweat and friction cause irritation.</p>",
            "icon": "",
            "color_scheme": "btn",
            "enable_open": false
          }
        },
        "content_MV4RBA": {
          "type": "content",
          "settings": {
            "heading": "Does it contain alcohol?",
            "content": "<p>No harsh alcohols.<br/><br/>No parabens.<br/><br/>No unnecessary fragrance.</p><p>Dermatology tested and hypoallergenic.</p>",
            "icon": "",
            "color_scheme": "btn",
            "enable_open": false
          }
        },
        "content_DHTzWy": {
          "type": "content",
          "settings": {
            "heading": "How often can I use it?",
            "content": "<p>Daily. Even multiple times per day if needed.</p><p>The formula is designed for repeat sweat cycles.</p>",
            "icon": "",
            "color_scheme": "btn",
            "enable_open": false
          }
        }
      },
