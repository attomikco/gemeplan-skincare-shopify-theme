{% comment %}
  GamePlan — Top Highlight Badge
  Renders the product highlight tags above the title.
  Usage: {% render 'gp-top-badge' %}
{% endcomment %}

<style>
  .gp-top-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: var(--type__font-smaller, 10px);
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--gc, #EF3340);
    border: 1px solid var(--gbr, #F0E0E0);
    padding: 4px 10px;
    border-radius: 4px;
    background: var(--gsoft, #FFF0F0);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }
</style>

<div class="gp-top-badge">🏃 Post-Sweat · Alcohol-Free · Biodegradable</div>
